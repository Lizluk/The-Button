-- =============================================
-- SCAN VÀ SET INFINITE AMMO & DURABILITY
-- =============================================
local function scanAndSetInfinite()
    local toolsFound = 0
    local ammoLocked = 0
    local durabilityLocked = 0
    
    -- Function để scan 1 tool
    local function scanTool(tool)
        toolsFound = toolsFound + 1
        
        -- SCAN ATTRIBUTES
        local attributes = tool:GetAttributes()
        
        for attrName, attrValue in pairs(attributes) do
            local name = attrName:lower()
            
            -- 1. AMMO ATTRIBUTES
            if name:find("ammo") or name:find("mag") or name:find("clip") then
                local maxAmmoAttr = tool:GetAttribute("MaxAmmo")
                
                if maxAmmoAttr then
                    tool:SetAttribute(attrName, maxAmmoAttr)
                else
                    tool:SetAttribute(attrName, 999)
                end
                
                if not scannedTools[tool.Name .. "_ammo"] then
                    scannedTools[tool.Name .. "_ammo"] = true
                    print(string.format("✅ [%s] Locked Ammo: %s", tool.Name, attrName))
                end
                
                ammoLocked = ammoLocked + 1
            end
            
            -- 2. DURABILITY ATTRIBUTES
            if name:find("durability") then
                local maxDurabilityAttr = tool:GetAttribute("MaxDurability")
                
                if maxDurabilityAttr then
                    tool:SetAttribute(attrName, maxDurabilityAttr)
                else
                    -- Nếu không có MaxDurability, set = "inf" string hoặc 999999
                    tool:SetAttribute(attrName, 999999)
                end
                
                if not scannedTools[tool.Name .. "_durability"] then
                    scannedTools[tool.Name .. "_durability"] = true
                    print(string.format("🛡️ [%s] Locked Durability: %s", tool.Name, attrName))
                end
                
                durabilityLocked = durabilityLocked + 1
            end
        end
        
        -- SCAN NUMBERVALUE/INTVALUE (Backup method)
        for _, obj in pairs(tool:GetDescendants()) do
            if obj:IsA("NumberValue") or obj:IsA("IntValue") then
                local name = obj.Name:lower()
                
                -- Ammo
                if name:find("ammo") or name:find("mag") or name:find("clip") or name:find("bullet") then
                    obj.Value = 999
                    ammoLocked = ammoLocked + 1
                end
                
                -- Durability
                if name:find("durability") or name:find("durablity") then
                    obj.Value = 999999
                    durabilityLocked = durabilityLocked + 1
                end
            end
        end
    end
    
    -- Scan Backpack
    for _, tool in pairs(backpack:GetChildren()) do
        if tool:IsA("Tool") then
            scanTool(tool)
        end
    end
    
    -- Scan Character (tool đang cầm)
    for _, tool in pairs(character:GetChildren()) do
        if tool:IsA("Tool") then
            scanTool(tool)
        end
    end
    
    return toolsFound, ammoLocked, durabilityLocked
end

-- =============================================
-- BẬT
-- =============================================
local function enable()
    enabled = true
    
    print("\n" .. string.rep("=", 70))
    print("AUTO INFINITE AMMO & DURABILITY - ENABLED")
    print(string.rep("=", 70))
    
    -- Scan ngay
    local tools, ammo, durability = scanAndSetInfinite()
    print(string.format("Initial scan: %d tools, %d ammo, %d durability", tools, ammo, durability))
    
    -- Update liên tục
    updateConn = RunService.Heartbeat:Connect(function()
        if not enabled then return end
        
        local toolsFound, ammoLocked, durabilityLocked = scanAndSetInfinite()
        
        -- Update GUI
        lbl.Text = string.format(
            "[K] Auto Inf: ON ⚡\n\nScanned: %d tools\nAmmo Locked: %d 🔫\nDurability Locked: %d 🛡️\n\nAuto-detect all attributes",
            toolsFound, ammoLocked, durabilityLocked
        )
    end)
    
    lbl.BackgroundColor3 = Color3.fromRGB(0, 40, 30)
    stroke.Color = Color3.fromRGB(0, 255, 150)
    
    game.StarterGui:SetCore("SendNotification", {
        Title = "∞ Auto Infinite ON",
        Duration = 2,
        Text = "Ammo + Durability locked!",
    })
end

-- =============================================
-- TẮT
-- =============================================
local function disable()
    enabled = false
    
    if updateConn then
        updateConn:Disconnect()
        updateConn = nil
    end
    
    table.clear(scannedTools)
    
    lbl.Text = "[K] Auto Inf: OFF\n\nScanned: 0 tools\nAmmo Locked: 0\nDurability Locked: 0\n\nAuto-detect all attributes"
    lbl.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
    stroke.Color = Color3.fromRGB(80, 80, 80)
    
    print("\n" .. string.rep("=", 70))
    print("AUTO INFINITE - DISABLED")
    print(string.rep("=", 70))
    
    game.StarterGui:SetCore("SendNotification", {
        Title = "✅ Auto Inf OFF",
        Duration = 2,
        Text = "Back to normal",
    })
end

-- =============================================
-- INPUT
-- =============================================
UserInputService.InputBegan:Connect(function(input, chat)
    if chat then return end
    
    if input.KeyCode == Enum.KeyCode.K then
        if not enabled then
            enable()
        else
            disable()
        end
    end
end)

-- =============================================
-- AUTO DETECT NEW TOOLS
-- =============================================
backpack.ChildAdded:Connect(function(child)
    if not enabled then return end
    
    if child:IsA("Tool") then
        task.wait(0.1)
        
        print(string.format("\n🔍 New tool detected: %s", child.Name))
        
        local attributes = child:GetAttributes()
        for attrName, attrValue in pairs(attributes) do
            local valueStr = tostring(attrValue)
            if #valueStr > 50 then
                valueStr = valueStr:sub(1, 47) .. "..."
            end
            print(string.format("  → %s = %s", attrName, valueStr))
        end
    end
end)

-- =============================================
-- RESPAWN
-- =============================================
player.CharacterAdded:Connect(function(newChar)
    character = newChar
    table.clear(scannedTools)
    
    if enabled then
        task.wait(1)
    end
end)

