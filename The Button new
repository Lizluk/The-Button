-- Scan và show info
local initialTools = 0

for _, tool in pairs(backpack:GetChildren()) do
    if tool:IsA("Tool") then
        initialTools = initialTools + 1
        print(string.format("\n📦 Tool: %s", tool.Name))
        
        local attributes = tool:GetAttributes()
        local hasAmmo = false
        local hasDurability = false
        
        for attrName, attrValue in pairs(attributes) do
            local name = attrName:lower()
            local valueStr = tostring(attrValue)
            
            if #valueStr > 50 then
                valueStr = valueStr:sub(1, 47) .. "..."
            end
            
            if name:find("ammo") or name:find("mag") then
                print(string.format("  🔫 %s = %s", attrName, valueStr))
                hasAmmo = true
            elseif name:find("durability") then
                print(string.format("  🛡️ %s = %s", attrName, valueStr))
                hasDurability = true
            else
                print(string.format("  → %s = %s", attrName, valueStr))
            end
        end
        
        if hasAmmo then
            print("  ✅ Has ammo attributes")
        end
        if hasDurability then
            print("  ✅ Has durability attributes")
        end
    end
end

if initialTools > 0 then
    print(string.format("\n✅ Found %d tools ready to lock!", initialTools))
