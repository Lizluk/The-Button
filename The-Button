        print(string.format("\n🔍 New tool detected: %s", child.Name))
        
        -- Scan attributes
        local attributes = child:GetAttributes()
        for attrName, attrValue in pairs(attributes) do
            print(string.format("  Attribute: %s = %s", attrName, tostring(attrValue)))
        end
    end
end)

-- =============================================
-- RESPAWN
-- =============================================
player.CharacterAdded:Connect(function(newChar)
    character = newChar
    table.clear(scannedTools)
    
    if enabled then
        task.wait(1)
    end
end)

